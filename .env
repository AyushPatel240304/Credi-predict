# PostgreSQL Database Connection
DB_HOST=localhost          # your machine
DB_PORT=5432               # PostgreSQL port (NOT Flask port, don't change)
DB_NAME=credipredict_db    # database we just created in pgAdmin
DB_USER=postgres           # default PostgreSQL username
DB_PASSWORD="admin"  # password you set during PostgreSQL installation

# Flask Security Key (random string, just keep it as is)
SECRET_KEY=credipredict-secret-key-2026

# Admin Panel Credentials (you decide these)
ADMIN_USERNAME=admin
ADMIN_PASSWORD="admin@123"  # set your own password for admin panel

